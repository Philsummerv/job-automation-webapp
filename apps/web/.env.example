# Copy to apps/web/.env.local and fill in from your Supabase project settings.

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-only, NEVER exposed to the browser.
# Used later by the Stripe webhook (M1) and the Guided worker (M2).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL (used for magic-link redirect and Stripe return URLs).
# In dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe — Developers → API keys (use test mode until launch). Server-only.
STRIPE_SECRET_KEY=sk_test_...
# In dev: printed by `stripe listen --forward-to localhost:3000/api/stripe/webhook`.
# In prod: from the dashboard webhook endpoint (events: checkout.session.completed,
# customer.subscription.created/updated/deleted).
STRIPE_WEBHOOK_SECRET=whsec_...
# The $12/mo recurring price id — create product "ApplyAssistUI" + price manually
# in the dashboard, then paste the id here.
STRIPE_PRICE_ID=price_...

# Comma-separated emails with complimentary access (paywall bypass) — the
# owner account, beta testers. Case-insensitive. Server-only.
COMPED_EMAILS=
