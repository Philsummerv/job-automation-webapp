# Copy to apps/web/.env.local and fill in from your Supabase project settings.

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-only, NEVER exposed to the browser.
# Used later by the Stripe webhook (M1) and the Guided worker (M2).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL (used for magic-link redirect). In dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
