# Copy to packages/automation/.env and fill in.

# Browserbase — https://www.browserbase.com → Settings → API keys.
# The key alone identifies the project (no project id needed).
# Free tier: 1 browser-hour total, ~15 min per session, no proxies.
BROWSERBASE_API_KEY=bb_...

# Optional: 2Captcha auto-solve for Cloudflare Turnstile. Without it the human
# solves captchas via the session live view.
TWOCAPTCHA_KEY=

# Optional: override the Browserbase session timeout (seconds, default 900 —
# the free-tier per-session cap).
BROWSERBASE_SESSION_TIMEOUT_SECONDS=
